# Database
DATABASE_URL=postgresql://openclaw:change_me@localhost:5432/openclaw_vps_manager

# Git Repository
GIT_REPO_PATH=/var/git/openclaw-configs
GIT_REPO_URL=git@github.com:your-org/openclaw-configs.git

# SSH Keys
SSH_KEYS_PATH=/var/ssh/keys
SSH_KEY_TYPE=ed25519
SSH_KEY_PASSPHRASE=

# Encryption
ENCRYPTION_KEY_PATH=/var/keys/encryption
ENCRYPTION_ALGORITHM=AES-256-GCM

# JWT
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# mTLS
TLS_CERT_PATH=/var/tls/cert.pem
TLS_KEY_PATH=/var/tls/key.pem
TLS_CA_CERT_PATH=/var/tls/ca.pem
TLS_VERIFY_CLIENT=true

# OpenClaw
OPENCLAW_DEFAULT_VERSION=latest
OPENCLAW_INSTALL_PATH=/usr/local/bin/openclaw
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
OPENCLAW_PORT=18789

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS
CORS_ORIGINS=["http://localhost:3000","https://vps-manager.example.com"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
